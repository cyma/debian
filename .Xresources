URxvt.font: xft:IBM Plex Mono:style=Regular:pixelsize=16
URxvt.boldFont: xft:IBM Plex Mono:style=Bold:pixelsize=16
URxvt.italicFont: xft:IBM Plex Mono:style=Italic:pixelsize=16

URxvt.letterSpace: 0
URxvt.lineSpace: 0

URxvt.pointerBlank: true
URxvt.scrollBar: false
URxvt.loginShell: true
URxvt.scrollTyOutput: false
URxvt.scrollWithBuffer: false
URxvt.skipScroll: true
URxvt.saveLines: 1000;

